# === Storage ===
# Set USE_FIRESTORE=1 to use Firestore. If empty, falls back to local JSON files.
USE_FIRESTORE=

# === OAuth ===
# Redirect URI for Google OAuth 2.0 (must match Google Cloud Console config)
# Leave empty for localhost:8501 (local dev)
OAUTH_REDIRECT_URI=

# === Security ===
# HMAC secret for client shared links (any random string, keep consistent)
CLIENT_LINK_SECRET=change-me-to-a-random-secret
