# === Storage ===
# Set DATABASE_URL to use PostgreSQL. If empty, falls back to local JSON files.
# Format: postgresql://user:password@host:5432/dbname
# Cloud SQL: postgresql://utm_app:PASSWORD@/utm_tool?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# === OAuth ===
# Redirect URI for Google OAuth 2.0 (must match Google Cloud Console config)
# Leave empty for localhost:8501 (local dev)
OAUTH_REDIRECT_URI=

# === Security ===
# HMAC secret for client shared links (any random string, keep consistent)
CLIENT_LINK_SECRET=change-me-to-a-random-secret
